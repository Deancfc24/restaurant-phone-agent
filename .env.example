# === Vapi.ai ===
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id

# === ElevenLabs (TTS via Vapi) ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# === LLM (used by Vapi) ===
# If using your own OpenAI / Anthropic key through Vapi:
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key

# === Webhook Server ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_webhook_secret

# === Restaurant Configuration ===
# Which reservation system to use: "ontopo" or "tabit"
RESERVATION_SYSTEM=ontopo

# Restaurant identifiers
RESTAURANT_NAME=My Restaurant
RESTAURANT_VENUE_ID=your_venue_id
RESTAURANT_CITY=tel-aviv

# === Tabit (if using Tabit) ===
TABIT_ORGANIZATION_ID=your_tabit_org_id
# TABIT_API_KEY=your_tabit_api_key

# === Server ===
LOG_LEVEL=info
