# === Vapi.ai (global account key) ===
VAPI_API_KEY=your_vapi_api_key

# === ElevenLabs (global — used for all restaurant assistants) ===
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# === Server ===
# Public URL where Vapi can reach this server (for webhooks)
SERVER_URL=https://your-domain.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# === Database ===
# SQLite by default — no setup needed
DATABASE_URL=sqlite:///data/restaurants.db

# === Logging ===
LOG_LEVEL=info
